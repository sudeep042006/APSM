# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/social-os
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/social-os
MONGODB_URI=mongodb://localhost:27017/social-os

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX
JWT_EXPIRES_IN=7d

# ── Token Encryption (AES-256) ────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX

# ── YouTube / Google ──────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "YouTube Data API v3"
# 3. OAuth consent screen → add scopes → add your email as test user
# 4. Credentials → Create OAuth 2.0 Client ID (Web application)
# 5. Add http://localhost:5000/auth/youtube/callback to Authorized redirect URIs
YOUTUBE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-your_secret

# ── Facebook + Instagram (same Meta app) ─────────────────────────────────────
# 1. Go to developers.facebook.com → My Apps → Create App
# 2. Add products: "Facebook Login" + "Instagram Graph API"
# 3. Settings → Basic → copy App ID and App Secret
# 4. Facebook Login → Settings → add http://localhost:5000/auth/facebook/callback
# 5. Instagram → add http://localhost:5000/auth/instagram/callback
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ── Server Configuration ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Connection ───────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/incubein

# ── Redis Connection ─────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── JWT Authentication ───────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── YouTube Data API ─────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ── LinkedIn OAuth ───────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Meta (Facebook + Instagram) Graph API ────────────────────────────
META_APP_ID=
META_APP_SECRET=

# ── Frontend Origin (CORS) ───────────────────────────────────────────
CLIENT_URL=http://localhost:5173
